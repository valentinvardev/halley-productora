# Copiá este archivo como ".env" y completá los valores.
# Al agregar una variable acá, actualizá también el schema en "/src/env.js".

# ---- Base de datos (Supabase) -------------------------------------------
# DATABASE_URL: connection string del "Session pooler" (puerto 5432).
# DIRECT_URL:   conexión directa, la usa Prisma para las migraciones.
#
# Elegí el proyecto en South America (São Paulo): cada pantalla hace varias
# consultas y todas pagan el viaje de ida y vuelta hasta la base.
DATABASE_URL="postgresql://postgres:password@localhost:5432/halley-app"
DIRECT_URL="postgresql://postgres:password@localhost:5432/halley-app"

# Sólo para mudar la base de región — ver "Mudar la base de región" en el
# README. Fuera de esa mudanza va comentada.
# DATABASE_URL_DESTINO=""

# ---- Panel de administración --------------------------------------------
ADMIN_PASSWORD="halley2026"
ADMIN_EMAIL="admin@halleyproducciones.com"

# ---- Talo ----------------------------------------------------------------
# mock = CVU/alias generados localmente + simulador de transferencias.
# real = Customers API de Talo (requiere TALO_API_URL y TALO_API_KEY).
TALO_MODE="mock"
# TALO_API_URL="https://api.talo.com.ar"
# TALO_API_KEY=""

# ---- Emails (Resend) -----------------------------------------------------
# bandeja = se registran en el panel sin enviarse (modo demo).
# resend  = además salen de verdad; requiere RESEND_API_KEY.
EMAIL_MODE="bandeja"
# RESEND_API_KEY="re_..."
# Hasta verificar el dominio en Resend, onboarding@resend.dev sólo puede
# escribirle a la casilla con la que creaste la cuenta.
EMAIL_FROM="Halley Producciones <onboarding@resend.dev>"

# ---- AWS S3 (contenido de la vitrina) ------------------------------------
# Todas opcionales: sin ellas la subida se apaga sola y la landing muestra las
# imágenes de relleno. AWS_S3_PREFIX es la carpeta de este cliente dentro del
# bucket — cambiala para aislar sus fotos de las de otro proyecto.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-2"
# AWS_S3_BUCKET="mediaseller-photos"
# AWS_S3_PREFIX="halley"

# ---- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
