// Halley — cobros a grupos de padres.
//
// El padre es una cuenta (email, sin contraseña) que reclama a uno o más
// alumnos. La cuota vive en el grupo como un plan de N vencimientos, y cada
// pago se imputa contra la cuota impaga más vieja del alumno.

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

/* -------------------------------------------------------------------------- */
/*  Grupo y plan de cuotas                                                     */
/* -------------------------------------------------------------------------- */

model Grupo {
    id      String @id @default(cuid())
    nombre  String // "Egresados 2027 – Colegio San Martín" o "Ana y Julián"
    slug    String @unique // link público de registro: /g/[slug]

    /// Para egresados, el colegio. Para un particular, el tipo de evento
    /// ("Boda", "15 años"): funciona igual como subtítulo, alias y en los
    /// avisos, así que se mantiene siempre cargado y nada aguas abajo cambia.
    colegio String

    /// Egresados —muchos alumnos que comparten un plan— o particular —un cliente
    /// único, una boda o un cumpleaños de 15, con su propio plan—. El modelo es
    /// el mismo; cambia cómo se gestiona y se muestra.
    tipo TipoCliente @default(EGRESADOS)

    /// Permite que los padres se registren solos desde el link del grupo.
    autoRegistro Boolean @default(true)

    cuotas         Cuota[]
    alumnos        Alumno[]
    galerias       Galeria[]
    notificaciones Notificacion[]

    creadoEn DateTime @default(now())
    /// A qué cuenta van los cobros de este grupo. Sin esto, la de por defecto.
    cuentaPagoId String?
    cuentaPago   CuentaPago? @relation(fields: [cuentaPagoId], references: [id], onDelete: SetNull)

}

/// Una cuota del plan: "la 3 de 6, $45.000, vence el 05/09".
model Cuota {
    id      String @id @default(cuid())
    grupoId String
    grupo   Grupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)

    numero  Int
    monto   Decimal  @db.Decimal(12, 2)
    venceEl DateTime

    pagos Pago[]

    creadoEn DateTime @default(now())

    @@unique([grupoId, numero])
    @@index([grupoId])
}

/* -------------------------------------------------------------------------- */
/*  Alumno y cuenta del padre                                                  */
/* -------------------------------------------------------------------------- */

model Alumno {
    id     String @id @default(cuid())
    nombre String

    grupoId String
    grupo   Grupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)

    /// Email al que el admin manda la invitación inicial, antes de que exista
    /// la cuenta. Opcional: el alumno puede cargarse sin conocerlo.
    emailContacto String?

    /// Quiénes gestionan la cuota de este alumno. Un chico puede tener dos
    /// papás —o un tutor más—, así que son varios y no uno; el tope está en
    /// MAX_RESPONSABLES.
    tutores Tutor[]

    /// Link personal sin login (/p/[token]). Sigue funcionando para el padre
    /// que no se quiere registrar y es el que ya salió por mail.
    token String @unique

    /// Customer de Talo: va por alumno, no por cuenta, para que cada
    /// transferencia se pueda imputar sin ambigüedad aunque haya hermanos.
    taloCustomerId String @unique
    cvu            String
    alias          String

    /// La familia avisó que transfirió. No confirma nada: sirve para cruzarlo
    /// contra lo que informa Talo.
    reportoTransferenciaEl DateTime?

    pagos          Pago[]
    notificaciones Notificacion[]

    creadoEn DateTime @default(now())

    @@index([grupoId])
}

/// Vínculo entre una cuenta y un alumno. Los responsables son todos iguales:
/// cualquiera ve el plan, paga y puede sacar a otro.
model Tutor {
    id String @id @default(cuid())

    cuentaId String
    cuenta   Cuenta @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
    alumnoId String
    alumno   Alumno @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

    creadoEn DateTime @default(now())

    @@unique([cuentaId, alumnoId])
    @@index([alumnoId])
    @@index([cuentaId])
}

/// Cuenta del padre. Sin contraseña: se entra con un link mandado al email.
model Cuenta {
    id     String  @id @default(cuid())
    email  String  @unique
    nombre String?

    tutorias Tutor[]
    sesiones Sesion[]

    creadoEn   DateTime  @default(now())
    ultimoAcceso DateTime?
}

/// Sesión abierta, referenciada por una cookie httpOnly.
model Sesion {
    id       String @id @default(cuid())
    token    String @unique
    cuentaId String
    cuenta   Cuenta @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

    expiraEl DateTime
    creadoEn DateTime @default(now())

    @@index([cuentaId])
}

/// Magic link: un solo uso, con vencimiento corto.
model EnlaceAcceso {
    id    String @id @default(cuid())
    token String @unique
    email String

    /// Si el link viene de un registro, el alumno que se está reclamando.
    alumnoId String?

    expiraEl DateTime
    usadoEl  DateTime?
    creadoEn DateTime  @default(now())

    @@index([email])
}

/* -------------------------------------------------------------------------- */
/*  Pagos                                                                      */
/* -------------------------------------------------------------------------- */

model Pago {
    id       String @id @default(cuid())
    alumnoId String
    alumno   Alumno @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

    /// Cuota contra la que se imputó. Se completa al recibir el pago: se aplica
    /// a la impaga más vieja.
    cuotaId String?
    cuota   Cuota?  @relation(fields: [cuotaId], references: [id], onDelete: SetNull)

    monto Decimal @db.Decimal(12, 2)
    /// Id único del pago en el proveedor: la transacción de Talo o el payment de
    /// Mercado Pago. Es la llave de idempotencia —el mismo pago no entra dos
    /// veces— y por eso da igual de qué proveedor venga. La columna sigue
    /// llamándose `taloTransactionId` para no migrar datos ya cargados.
    refPago String @unique @map("taloTransactionId")

    recibidoEn DateTime @default(now())

    @@index([alumnoId])
    @@index([cuotaId])
}

/* -------------------------------------------------------------------------- */
/*  Galería                                                                    */
/* -------------------------------------------------------------------------- */

/// Galería del grupo. Por ahora es el link de Drive que carga el admin; el
/// visor propio con las fotos alojadas entra en la etapa siguiente.
model Galeria {
    id      String @id @default(cuid())
    grupoId String
    grupo   Grupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)

    titulo    String
    linkDrive String?
    /// La galería alojada dura un año; después queda sólo el respaldo en Drive.
    venceEl   DateTime?

    fotos FotoGaleria[]

    creadoEn DateTime @default(now())

    @@index([grupoId])
}

/// Una pieza entregable de la galería de un grupo.
///
/// Es material privado de la familia, no la vitrina pública: se guarda en el
/// mismo bucket pero se sirve siempre firmado y con permiso chequeado, nunca
/// por el CDN abierto.
model FotoGaleria {
    id        String  @id @default(cuid())
    galeriaId String
    galeria   Galeria @relation(fields: [galeriaId], references: [id], onDelete: Cascade)

    s3Key String @unique
    /// El nombre original, que es con el que se descarga.
    nombre String
    tipo   String @default("imagen")
    orden  Int    @default(0)

    creadoEn DateTime @default(now())

    @@index([galeriaId, orden])
}

/* -------------------------------------------------------------------------- */
/*  Notificaciones                                                             */
/* -------------------------------------------------------------------------- */

/// Bandeja de salida: todo mensaje que el sistema dispara queda registrado acá
/// y se muestra en el panel. Con EMAIL_MODE=resend además sale por Resend.
model Notificacion {
    id           String           @id @default(cuid())
    tipo         TipoNotificacion
    destinatario String
    asunto       String
    cuerpo       String

    enviadoEl  DateTime?
    resendId   String?
    errorEnvio String?

    alumnoId String?
    alumno   Alumno? @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
    grupoId  String?
    grupo    Grupo?  @relation(fields: [grupoId], references: [id], onDelete: Cascade)

    creadoEn DateTime @default(now())

    @@index([creadoEn])
}

/// Sólo existe mientras Talo está en modo mock: guarda las transferencias
/// simuladas para que el webhook pueda confirmar monto y fecha igual que lo
/// haría contra `GET /customers/{id}/transactions/{id}`.
model TransaccionMockTalo {
    id         String   @id
    customerId String
    monto      Decimal  @db.Decimal(12, 2)
    creadoEn   DateTime @default(now())

    @@index([customerId])
}

/// Espejo de un pago de Mercado Pago en modo demo. Guarda lo que en producción
/// vive en la cuenta del socio, para que el flujo de Checkout Pro —crear la
/// preferencia, redirigir, volver, confirmar por webhook— se pueda recorrer
/// entero sin credenciales reales ni plata de verdad.
model TransaccionMockMercadoPago {
    id                String   @id
    cuentaPagoId      String
    /// El id del alumno, tal como viaja en external_reference.
    referenciaExterna String
    monto             Decimal  @db.Decimal(12, 2)
    /// Se marca cuando la pantalla demo confirma el pago.
    aprobadoEn        DateTime?
    creadoEn          DateTime @default(now())

    @@index([cuentaPagoId])
}

/// Una cuenta que recibe cobros. Cada socio puede tener la suya —en Talo o en
/// Mercado Pago— y cada grupo se rutea a una: así el dinero de un evento cae en
/// la cuenta que corresponde sin tocar código.
///
/// Las credenciales viven acá y nunca salen del servidor: el panel sólo ve los
/// últimos caracteres para reconocerlas.
model CuentaPago {
    id           String        @id @default(cuid())
    nombre       String
    proveedor    ProveedorPago
    /// Token de Talo o access token de Mercado Pago.
    credencial   String
    /// Sólo Talo: permite apuntar a otro entorno.
    apiUrl       String?
    activa       Boolean       @default(true)
    /// La que se usa cuando un grupo no eligió ninguna.
    porDefecto   Boolean       @default(false)
    creadoEn     DateTime      @default(now())
    grupos       Grupo[]

    @@index([activa])
}

/// Ajustes del sitio que el admin edita sin tocar código: el WhatsApp al que
/// escriben las familias, el Instagram, la casilla de contacto. Clave/valor para
/// que sumar uno nuevo no pida una migración.
model Ajuste {
    clave         String   @id
    valor         String
    actualizadoEn DateTime @updatedAt
}

/// Una pieza de la vitrina: la foto o el video que el admin sube por categoría
/// y que la landing muestra. `s3Key` es la ruta del objeto dentro del bucket
/// (sin el prefijo del cliente, que lo pone la capa de S3). `orden` fija en qué
/// posición se ve dentro de su categoría.
model Contenido {
    id        String   @id @default(cuid())
    categoria String
    s3Key     String   @unique
    tipo      String   @default("imagen")
    orden     Int      @default(0)
    creadoEn  DateTime @default(now())

    @@index([categoria, orden])
}

enum ProveedorPago {
    TALO
    MERCADOPAGO
}

enum TipoCliente {
    EGRESADOS
    PARTICULAR
}

enum EstadoCuota {
    PENDIENTE
    PAGADA
    VENCIDA
}

enum TipoNotificacion {
    INVITACION
    ACCESO
    CONFIRMACION_PADRE
    AVISO_ADMIN
    RECORDATORIO
}
